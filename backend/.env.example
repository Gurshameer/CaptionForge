# CaptionForge Configuration

# General Application Config
ENV=development
HOST=127.0.0.1
PORT=8000

# File Storage Config (Paths relative to project root or absolute)
UPLOAD_DIR=uploads
OUTPUT_DIR=generated_subtitles
LOG_DIR=logs
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes

# Faster-Whisper ASR Config
# Models: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu          # 'cpu' or 'cuda'
WHISPER_COMPUTE_TYPE=int8   # 'int8', 'float16', or 'default'

# OpenRouter Gemma 3:12B API Config
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-12b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
